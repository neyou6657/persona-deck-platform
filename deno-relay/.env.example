HOST=0.0.0.0
PORT=8000

# Shared secret used by the HF Space agent when it opens /agent
AGENT_SHARED_SECRET=replace-me
AGENT_REQUEST_TIMEOUT_MS=90000
AGENT_TOOL_SHARED_SECRET=replace-me

# PostgreSQL becomes the durable system of record
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
PGVECTOR_EMBED_DIM=1536
KNOWLEDGE_SEARCH_LIMIT=8
KNOWLEDGE_WRITEBACK_MODE=explicit

# Admin auth / session controls
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=24

# Optional local testing mode before HF is deployed
MOCK_MODE=false
MOCK_REPLY_PREFIX=Mock relay reply
