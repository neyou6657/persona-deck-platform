HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgres://user:password@host:5432/app?sslmode=require
PGVECTOR_EMBED_DIM=1536

# Shared secret used by the HF Space agent when it opens /agent
AGENT_SHARED_SECRET=replace-me
AGENT_TOOL_SHARED_SECRET=replace-me
AGENT_REQUEST_TIMEOUT_MS=90000
AGENT_TOKEN_PERSONAS_JSON={"replace-me":["default"]}
PERSONA_CATALOG_JSON=[]

ADMIN_PASSWORD_HASH=sha256:replace-me
ADMIN_SESSION_SECRET=replace-me
ADMIN_SESSION_TTL_HOURS=24

KNOWLEDGE_SEARCH_LIMIT=8
KNOWLEDGE_WRITEBACK_MODE=explicit
